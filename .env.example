# Server/script-only photo API keys.
# Do not prefix these with VITE_ and do not commit real keys.
SITE_URL=https://calmbeach.gr
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
WIKIMEDIA_ENTERPRISE_ACCESS_TOKEN=
WIKIMEDIA_ENTERPRISE_USERNAME=
WIKIMEDIA_ENTERPRISE_PASSWORD=
WIKIMEDIA_ENTERPRISE_QUERY_LIMIT=3

# Server/script-only audit report email settings.
# Do not commit real keys or personal email addresses here.
RESEND_API_KEY=
AUDIT_EMAIL_FROM=BeachBuddy Audit <audit@example.com>
AUDIT_EMAIL_TO=you@example.com
AUDIT_EMAIL_CC=
AUDIT_EMAIL_BCC=
AUDIT_EMAIL_SUBJECT_PREFIX=BeachBuddy Audit Report

# Local admin GUI for audit reports and schedules.
AUDIT_ADMIN_TOKEN=change-this-local-admin-token
AUDIT_ADMIN_HOST=127.0.0.1
AUDIT_ADMIN_PORT=4187
AUDIT_ADMIN_RUN_TIMEOUT_MS=900000
