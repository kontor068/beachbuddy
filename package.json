{
  "name": "calm-beach-greece",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:beach-data": "node scripts/buildBeachRegionData.mjs",
    "audit:beaches": "node scripts/auditBeachDataset.mjs",
    "quality:explain": "node scripts/runCriticalQualityChecks.mjs --explain",
    "quality:beach-data": "node scripts/validateCriticalBeachData.mjs",
    "quality:critical": "node scripts/runCriticalQualityChecks.mjs",
    "quality:auto": "node scripts/runCriticalQualityChecks.mjs --auto --max-attempts=3",
    "content:audit": "node scripts/auditStaticBeachContent.mjs",
    "photos:milos": "node scripts/findMilosBeachImages.mjs",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "images:backgrounds": "node scripts/optimizeBackgroundImages.mjs",
    "photos:destinations:cards": "node scripts/optimizeDestinationCardImages.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.16.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-firebase-hooks": "^5.1.1",
    "react-leaflet": "^5.0.0",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "sharp": "^0.34.5"
  }
}
